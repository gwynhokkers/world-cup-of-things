# Session: min 32 chars for cookie encryption
NUXT_SESSION_PASSWORD=your-session-secret-at-least-32-characters-long

# OAuth (create app on GitHub / Google Cloud Console)
# nuxt-auth-utils expects NUXT_OAUTH_*; these are also supported:
NUXT_GITHUB_CLIENT_ID=
NUXT_GITHUB_CLIENT_SECRET=
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

# Admin roles: comma-separated provider user IDs (GitHub id, Google sub)
ADMIN_GITHUB_IDS=
ADMIN_GOOGLE_IDS=

# Cloudflare (production only)
# NUXT_HUB_CLOUDFLARE_DATABASE_ID=
# NUXT_HUB_CLOUDFLARE_BUCKET_NAME=
